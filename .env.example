# Anthropic (used as Overseer + Gold Standard Source).
ANTHROPIC_API_KEY=

# OpenRouter (optional — only required when a task's config.yaml lists a
# target_model with provider: openrouter). Obtain at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override LM Studio base URL. Default: http://localhost:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ---- Gold Standard Source routing (optional) --------------------------------
# The Gold Standard Source generates reference outputs for each eval example
# at setup. By default it calls Anthropic directly. Set the vars below to
# route it through OpenRouter instead (useful when you have OpenRouter credit
# but no direct Anthropic billing relationship).
#
# GOLD_STANDARD_PROVIDER=anthropic       # or: openrouter
# GOLD_STANDARD_MODEL=                   # e.g. claude-opus-4-7 (Anthropic) or
#                                        #      anthropic/claude-opus-4.6 (OpenRouter)
# GOLD_STANDARD_BASE_URL=                # OpenRouter-only; default is the
#                                        # standard https://openrouter.ai/api/v1
# GOLD_STANDARD_API_KEY_ENV=             # env-var name holding the key;
#                                        # defaults to ANTHROPIC_API_KEY or
#                                        # OPENROUTER_API_KEY based on provider
